# Cloudflare Worker configuration for stage-flow-tools
# Copy this file to wrangler.toml and fill in your values.
# See docs/deployment-cloudflare.md for setup instructions.

name = "stage-flow-tools"
main = ".output/server/index.mjs"
compatibility_date = "2025-07-15"

[vars]
NUXT_ADMIN_USERNAME = "admin"
NUXT_PUBLIC_EMOJI_COOLDOWN_MS = "1500"

# Secrets (set via `npx wrangler secret put`):
# NUXT_ADMIN_PASSWORD
# NUXT_JWT_SECRET

[[kv_namespaces]]
binding = "STAGE_FLOW_DATA"
id = "<your-kv-namespace-id>"
preview_id = "<your-preview-kv-namespace-id>"
